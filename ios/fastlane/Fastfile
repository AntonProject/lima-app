# iOS release lane — issues the distribution cert + App Store profile via the
# App Store Connect API key, builds a signed IPA, and uploads it to TestFlight.
# Flutter precompiles the unsigned .app first; fastlane does archive/sign/export
# (more reliable than bare `xcodebuild -exportArchive -allowProvisioningUpdates`,
# which fails with "expected results but none were found" when the profile has
# to be created on the fly).
#
# Auth env vars (written from GitHub secrets in the workflow):
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH (path to AuthKey_*.p8)

default_platform(:ios)

APP_IDENTIFIER = "uz.lima.lima"
TEAM_ID = "5N9G35WULY"

platform :ios do
  desc "Build, sign and upload to TestFlight via ASC API key"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false,
    )

    # The distribution certificate is imported into the runner keychain by the
    # workflow (from the IOS_DIST_CERT_P12_BASE64 secret) — we do NOT call
    # `cert`, which would try to create a new one and hit Apple's distribution
    # certificate limit. We only fetch/refresh the App Store provisioning
    # profile via the API key.
    sigh(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      development: false,
      platform: "ios",
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      output_directory: "../build/ios/ipa",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: { APP_IDENTIFIER => profile_name },
      },
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} CODE_SIGN_STYLE=Manual",
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
    )
  end

  # Kept for manual use: upload an already-built IPA.
  desc "Upload a prebuilt IPA to TestFlight"
  lane :deploy do |options|
    ipa = options[:ipa] || Dir["../build/ios/ipa/*.ipa"].first
    UI.user_error!("No .ipa found in build/ios/ipa") if ipa.nil?
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false,
    )
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
    )
  end
end
